{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "node_modules", "cdk.out"]
  },
  "context": {
    "stage": "dev",
    "reminderCron": "cron(0 0 25,28 * ? *)",
    "hrUserIds": "",
    "masterHrPrefix": "sonsik",
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true
  }
}
